# PostgreSQL connection string
# Local:    postgres://postgres:postgres@127.0.0.1:5432/joodlife
# Vercel Postgres / Neon / Supabase: paste the pooled connection string here
DATABASE_URI=postgres://postgres:postgres@127.0.0.1:5432/joodlife

# Payload secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=replace-with-a-long-random-string

# Public URL for the site (used for CORS / media URLs)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: seed script admin credentials (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@joodlife.com
SEED_ADMIN_PASSWORD=ChangeMe123!
